# Copy to .env.local and fill in (all free).
# The app runs without any keys: live scores fall back to worldcup26.ir
# (no auth), match stats/lineups/players come from ESPN's public API,
# Polymarket odds, flags and stadium imagery never need keys.

# football-data.org — free tier (10 req/min). Register:
# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# GNews.io — free tier (100 req/day). Register: https://gnews.io/
# Responses are cached 10 minutes server-side and requests are paced to
# protect the daily quota.
GNEWS_API_KEY=

# OPTIONAL — SeatGeek resale ticket prices on match pages.
# Free client id: https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=

# OPTIONAL — real on-site viewer counts (concurrent "watching now" + cumulative
# "viewers" per match), counting actual visitors to THIS dashboard.
# Without these two, the match page shows only the labeled global-audience
# ESTIMATE and hides the real counters. Create a free Upstash Redis database
# (https://upstash.com → Redis → "REST API" tab) and paste its REST URL + token.
# Free tier: 256MB / 500K commands per month — ample for a personal dashboard.
# Also powers: persistent API response caching, live match reactions, push
# subscriptions, and a fallback prediction pool if Supabase is not configured.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL but recommended — office prediction pool database.
# Option A: paste Supabase's pooled connection string directly.
#   Supabase dashboard → Project Settings → Database → Connection string → Transaction pooler
POSTGRES_URL=
# Option B: let the app infer the connection from your project URL + password.
#   Set SUPABASE_INFER_DIRECT_DB=true, then fill DATABASE_URL (your Supabase project URL,
#   e.g. https://xxxx.supabase.co) and DATABASE_PASSWORD.
SUPABASE_INFER_DIRECT_DB=
DATABASE_URL=
DATABASE_PASSWORD=
# Supabase REST keys (used for client-side auth if added later)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# The app auto-creates pool_users, pool_sessions, pool_picks, and golden_ball_code
# on first use — no manual migration needed. Never commit real values to git.

# OPTIONAL — Ballon d'Or bonus: set to a candidate ID from data/ballon-dor-candidates.ts
# once the winner is announced. Users who picked this player get +15 pts.
WC26_GOLDEN_BALL=

# OPTIONAL — require an invite code when coworkers register.
OFFICE_POOL_CODE=

# OPTIONAL — push notifications (goal alerts + kickoff reminders). Needs Upstash
# (above) AND VAPID keys. Generate with:  npx web-push generate-vapid-keys
# (the client fetches the public key from the API — no NEXT_PUBLIC_ var needed).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Protects the /api/cron/alerts endpoint. There is NO Vercel cron configured
# (Hobby plan rejects the per-minute schedule that goal alerts need, which fails
# the deployment). To enable alerts, point a free external cron (e.g. cron-job.org)
# at  /api/cron/alerts?key=<this value>  every minute — or, on a Vercel Pro plan,
# add your own crons entry to vercel.json.
CRON_SECRET=
